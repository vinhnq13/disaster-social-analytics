@startuml Disaster Social Media Analytics - Class Diagram
title Disaster Social Media Analytics System\nClass Diagram (OOP Architecture)

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam packageStyle rectangle
skinparam linetype ortho

' --- Model ---

package "com.dsa.model" {
  class Post {
    - content : String
    - date : String
    - source : String
    --
    + Post()
    + Post(content, date, source)
    + getContent() : String
    + setContent(content) : void
    + getDate() : String
    + setDate(date) : void
    + getSource() : String
    + setSource(source) : void
    + toString() : String
  }
}

' --- Collector ---

package "com.dsa.collector" {
  interface DataCollector {
    + collect() : List<Post>
  }

  class JsonDataCollector {
    - {static} POSTS_RESOURCE : String
    - gson : Gson
    --
    + JsonDataCollector()
    + collect() : List<Post>
  }

  DataCollector <|.. JsonDataCollector
}

' --- Config ---

package "com.dsa.config" {
  class KeywordConfigLoader {
    - gson : Gson
    --
    + KeywordConfigLoader()
    + loadDamageKeywords() : Map<String, List<String>>
    + loadSentimentKeywords() : Map<String, List<String>>
    + loadReliefKeywords() : Map<String, List<String>>
  }
}

' --- Preprocess ---

package "com.dsa.preprocess" {
  interface TextPreprocessor {
    + clean(text : String) : String
  }

  class BasicTextPreprocessor {
    + clean(text : String) : String
  }

  TextPreprocessor <|.. BasicTextPreprocessor
}

' --- Sentiment ---

package "com.dsa.sentiment" {
  interface SentimentModel {
    + classify(text : String) : String
    + getSentiments() : List<String>
  }

  class KeywordSentimentModel {
    - textPreprocessor : TextPreprocessor
    - sentimentKeywords : Map<String, List<String>>
    --
    + KeywordSentimentModel(textPreprocessor, sentimentKeywords)
    + classify(text : String) : String
    + getSentiments() : List<String>
  }

  SentimentModel <|.. KeywordSentimentModel
}

' --- Service ---

package "com.dsa.service" {
  class DataService {
    - dataCollector : DataCollector
    --
    + DataService()
    + DataService(dataCollector : DataCollector)
    + loadPosts() : List<Post>
  }

  class AnalysisService {
    - damageAnalyzer : DamageAnalyzer
    - sentimentAnalyzer : SentimentAnalyzer
    - sentimentTrendAnalyzer : SentimentTrendAnalyzer
    - reliefSatisfactionAnalyzer : ReliefSatisfactionAnalyzer
    --
    + AnalysisService(damage, sentiment, trend, relief)
    + {static} createDefault() : AnalysisService
    + analyzeDamage(posts) : Map<String, Integer>
    + analyzeSentiment(posts) : Map<String, Integer>
    + analyzeSentimentTrend(posts) : Map<String, Map<String, Integer>>
    + analyzeReliefSatisfaction(posts) : Map<String, Integer>
  }
}

' --- Analyzer ---

package "com.dsa.analyzer" {
  interface Analyzer {
    + analyze(posts : List<Post>) : Map<String, Integer>
  }

  class DamageAnalyzer {
    - textPreprocessor : TextPreprocessor
    - categoryKeywords : Map<String, List<String>>
    --
    + DamageAnalyzer(textPreprocessor, damageKeywords)
    + analyze(posts) : Map<String, Integer>
  }

  class SentimentAnalyzer {
    - sentimentModel : SentimentModel
    --
    + SentimentAnalyzer(sentimentModel)
    + analyze(posts) : Map<String, Integer>
  }

  class SentimentTrendAnalyzer {
    - sentimentModel : SentimentModel
    --
    + SentimentTrendAnalyzer(sentimentModel)
    + analyze(posts) : Map<String, Map<String, Integer>>
  }

  class ReliefSatisfactionAnalyzer {
    - textPreprocessor : TextPreprocessor
    - reliefKeywords : Map<String, List<String>>
    - sentimentModel : SentimentModel
    --
    + ReliefSatisfactionAnalyzer(textPreprocessor, reliefKeywords, sentimentModel)
    + analyze(posts) : Map<String, Integer>
  }

  Analyzer <|.. DamageAnalyzer
  Analyzer <|.. SentimentAnalyzer
  Analyzer <|.. ReliefSatisfactionAnalyzer
}

' --- UI ---

package "com.dsa.ui" {
  class DashboardApp {
    + {static} main(args : String[])
    + start(stage : Stage) : void
  }

  class DashboardController {
    - dataService : DataService
    - analysisService : AnalysisService
    --
    + DashboardController()
    + getRoot() : BorderPane
  }

  class ChartBuilder <<utility>>
  class ResultFormatter <<utility>>
}

' --- Config resources (classpath) ---

together {
  object "damage-keywords.json" as damageJson <<config file>>
  object "sentiment-keywords.json" as sentimentJson <<config file>>
  object "relief-keywords.json" as reliefJson <<config file>>
}

' --- Application entry ---

package "com.dsa" {
  class Main {
    + {static} main(args : String[]) : void
    - {static} printResults(...) : void
    - {static} printSentimentTrendResults(...) : void
  }
}

' --- Data flow ---

Main --> DataService : load posts
Main --> AnalysisService : analyze

DashboardApp ..> DashboardController : creates
DashboardController --> DataService : load posts
DashboardController --> AnalysisService : analyze

DataService o--> DataCollector
DataService ..> JsonDataCollector : default

JsonDataCollector ..> Post : returns

KeywordConfigLoader ..> damageJson : reads
KeywordConfigLoader ..> sentimentJson : reads
KeywordConfigLoader ..> reliefJson : reads

AnalysisService o--> DamageAnalyzer
AnalysisService o--> SentimentAnalyzer
AnalysisService o--> SentimentTrendAnalyzer
AnalysisService o--> ReliefSatisfactionAnalyzer

AnalysisService ..> KeywordConfigLoader : createDefault()
AnalysisService ..> KeywordSentimentModel : createDefault()
AnalysisService ..> BasicTextPreprocessor : createDefault()

DamageAnalyzer --> TextPreprocessor
ReliefSatisfactionAnalyzer --> TextPreprocessor

SentimentAnalyzer --> SentimentModel
SentimentTrendAnalyzer --> SentimentModel
ReliefSatisfactionAnalyzer --> SentimentModel

KeywordSentimentModel --> TextPreprocessor

KeywordConfigLoader ..> DamageAnalyzer : keywords via\nAnalysisService.createDefault()
KeywordConfigLoader ..> KeywordSentimentModel : sentiment keywords
KeywordConfigLoader ..> ReliefSatisfactionAnalyzer : relief keywords

DamageAnalyzer ..> Post
SentimentAnalyzer ..> Post
SentimentTrendAnalyzer ..> Post
ReliefSatisfactionAnalyzer ..> Post

note right of SentimentTrendAnalyzer
  Does not implement Analyzer
  (returns nested Map by date)
end note

note bottom of KeywordConfigLoader
  Loads JSON from
  src/main/resources/config/
  Injected into analyzers
  through AnalysisService
end note

note right of DamageAnalyzer
  categoryKeywords : Map
  loaded from damage-keywords.json
end note

note right of ReliefSatisfactionAnalyzer
  reliefKeywords from relief-keywords.json
  sentiment via SentimentModel
end note

note bottom of AnalysisService
  Central orchestration:
  add analyzer + method here
end note

note bottom of DataCollector
  Future: YouTubeDataCollector,
  FacebookDataCollector, XDataCollector
end note

@enduml
